{
  "expo": {
    "name": "ParkSpot",
    "slug": "parkingspotapp",
    "scheme": "parkspot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D2137"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.parkspot.app",
      "usesAppleSignIn": true,
      "config": {
        "googleMapsApiKey": "AIzaSyCiRTCJBWv5Ws09drozNPflqeQpEiL6Bog"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to show nearby parking spots.",
        "NSLocationAlwaysUsageDescription": "This app needs access to your location to show nearby parking spots.",
        "NSCameraUsageDescription": "This app needs camera access to take photos of parking spots.",
        "NSPhotoLibraryUsageDescription": "This app needs photo library access to upload parking spot images.",
        "UIViewControllerBasedStatusBarAppearance": true,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.647587380585-lfqvq6ruaqi8hnsik291oejvenf3n0jc"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.647587380585-lfqvq6ruaqi8hnsik291oejvenf3n0jc"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D2137"
      },
      "package": "com.parkspot.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCKRB5fHipq7inuT1oO16i4xNJDKAafeUg"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.DETECT_SCREEN_CAPTURE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow ParkSpot to use your location to find nearby parking spots."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ParkSpot to access your photos to upload parking spot images.",
          "cameraPermission": "Allow ParkSpot to take photos of parking spots."
        }
      ],
      "expo-apple-authentication",
      "expo-font",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.parkspot.app",
          "enableGooglePay": true
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.647587380585-lfqvq6ruaqi8hnsik291oejvenf3n0jc"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0bfa799c-c50b-43eb-ad19-2d0687929d58"
      }
    },
    "owner": "pratik4094"
  }
}
