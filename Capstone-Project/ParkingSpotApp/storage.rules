rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Parking spot images — authenticated users upload, anyone can read
    match /parkingSpots/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User profile images — only the owner can write, anyone can read
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
